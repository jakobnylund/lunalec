# Resend API key — required for the contact form to actually send mail.
# Get one from https://resend.com → API Keys (sending access is enough).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where contact-form submissions are forwarded. Defaults to info@lunalec.com.
# CONTACT_TO=info@lunalec.com

# Sender used by Resend. Domain must be verified in Resend before this works
# (until then, fall back to Resend's onboarding domain or skip override).
# CONTACT_FROM=LunaLEC <noreply@lunalec.com>

# Canonical site URL for sitemap, robots and OG metadata.
# NEXT_PUBLIC_SITE_URL=https://lunalec.com
